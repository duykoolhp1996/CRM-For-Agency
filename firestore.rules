rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // 
    // Collection: users
    // Fields: displayName (string), email (string), photoURL (string), role (string), createdAt (timestamp)
    //
    // Collection: leads
    // Fields: name (string), company (string), email (string), status (string), value (number), source (string), ownerId (string), createdAt (timestamp)
    //
    // Collection: clients
    // Fields: name (string), company (string), email (string), ownerId (string), createdAt (timestamp)
    //
    // Collection: projects
    // Fields: name (string), clientId (string), status (string), budget (number), ownerId (string)
    //
    // Collection: tasks
    // Fields: title (string), projectId (string), status (string), ownerId (string)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'role']) &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string && data.role in ['Admin', 'Manager', 'Member'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'company', 'status', 'ownerId']) &&
             data.name is string && data.company is string &&
             data.status in ['New', 'Contacted', 'Qualified', 'Proposal', 'Won', 'Lost'] &&
             data.ownerId == request.auth.uid;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
    }

    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidLead(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId) && isValidLead(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    match /revenues/{revenueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    match /acceptances/{acceptanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isOwner(resource.data.ownerId);
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }
  }
}
